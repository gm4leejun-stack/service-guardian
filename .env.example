# AI Supervisor Environment Variables
# Copy this to .env and fill in your values

# Telegram Bot Token (@jun_xiao_code_bot)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Custom Anthropic base URL (for proxy)
# ANTHROPIC_BASE_URL=https://llmapi.lovbrowser.com

# Optional: Model override
# CLAUDE_MODEL=claude-sonnet-4-6
# HAIKU_MODEL=claude-haiku-4-5-20251001

# Optional: Admin Telegram user ID for watchdog alerts
# ADMIN_CHAT_ID=your_telegram_user_id_here
